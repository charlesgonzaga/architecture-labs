.gitignore para solução .NET / Visual Studio / VS Code
# Ignora binários e artefatos de build
[Bb]in/
[Oo]bj/
**/bin/
**/obj/
artifacts/

# Visual Studio
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

# Rider
.idea/
*.sln.iml

# NuGet
packages/
*.nupkg
.nuget/
project.lock.json
project.fragment.lock.json

# Visual Studio Code
.vscode/

# Test results and coverage
TestResults/
*.trx
*.coverage
coverage*.xml
*.coveragexml

# Resharper
_ReSharper*/
*.DotSettings.user

# Logs
*.log

# Publish
publish/
wwwroot/

# Temporary files
*.tmp
*.temp
*.cache

# OS files
Thumbs.db
desktop.ini
.DS_Store

# Secret e configurações locais
secrets.json
appsettings.*.Development.json
appsettings.*.Local.json

# Docker overrides
docker-compose.override.yml

# Ignore build output folders from example projects
examples/**/bin/
examples/**/obj/

# Ignore coverage and test result folders commonly generated by CI/tools
.coverage
coverage/

# JetBrains
/.idea/
